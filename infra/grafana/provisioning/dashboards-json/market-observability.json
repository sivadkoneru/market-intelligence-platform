      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "data": {
            "query": "SELECT TIME_FLOOR(ticks.__time, 'PT5M') AS bucket, ticks.symbol, AVG(ticks.price) AS avg_price, AVG(indicators.rsi) AS avg_rsi FROM ticks LEFT JOIN indicators ON ticks.symbol = indicators.symbol AND ticks.__time = indicators.__time WHERE ticks.__time >= CURRENT_TIMESTAMP - INTERVAL '6' HOUR AND ticks.symbol = '${symbol}' GROUP BY 1, 2 ORDER BY 1, 2",
            "resultFormat": "table"
          },
          "headers": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "method": "POST",
          "parser": "backend",
          "refId": "A",
          "url": "http://druid:8888/druid/v2/sql"
        }
      ],
      "title": "Druid market and indicator rows",
      "type": "table"
    },
    {
      "datasource": {
        "type": "marcusolsson-json-datasource",
