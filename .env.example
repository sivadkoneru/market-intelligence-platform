# -----------------------------------------------------------------------
# .env.example — environment variables consumed by docker-compose.yml
# Copy to .env and adjust values before running `task up`.
# DO NOT commit .env (it is in .gitignore).
# -----------------------------------------------------------------------

# ---- Azure Service Bus Emulator + SQL Server --------------------------
# Strong password: >=8 chars, upper, lower, digit, special.
MSSQL_SA_PASSWORD=Str0ng!Passw0rd

# ---- PostgreSQL (app metadata + Druid metadata store) -----------------
POSTGRES_USER=mip
POSTGRES_PASSWORD=mip_local
POSTGRES_DB=mip

# ---- Druid metadata store credentials (must match above or separate) --
DRUID_POSTGRES_USER=druid
DRUID_POSTGRES_PASSWORD=druid

# ---- Redis (no auth by default for local dev) -------------------------
# REDIS_PASSWORD=

# ---- Elasticsearch (security disabled for local dev) ------------------
# ES_JAVA_OPTS is set inline in compose; override here if needed.
# ES_JAVA_OPTS=-Xms512m -Xmx512m

# ---- Grafana ----------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- Optional: LLM keys (services fall back to MOCK_LLM if absent) ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# ANTHROPIC_API_KEY=
# MOCK_LLM=1

# ---- Optional: New Relic APM (opt-in) ---------------------------------
# NEW_RELIC_LICENSE_KEY=
