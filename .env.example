# -----------------------------------------------------------------------
# .env.example — environment variables consumed by docker-compose.yml
# Copy to .env and adjust values before running `task up`.
# DO NOT commit .env (it is in .gitignore).
# -----------------------------------------------------------------------

# ---- Azure Service Bus Emulator + Azure SQL Edge ----------------------
# SQL Edge backs the emulator and runs natively on arm64 (Apple Silicon).
# Strong password: >=8 chars, upper, lower, digit, special.
MSSQL_SA_PASSWORD=Str0ng!Passw0rd

# ---- PostgreSQL (app metadata + Druid metadata store) -----------------
POSTGRES_USER=mip
POSTGRES_PASSWORD=mip_local
POSTGRES_DB=mip

# ---- Druid metadata store credentials (keep aligned with Postgres) ----
DRUID_POSTGRES_USER=mip
DRUID_POSTGRES_PASSWORD=mip_local
DRUID_POSTGRES_DB=mip

# ---- App connection defaults for local host-side tools/scripts --------
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
REDIS_URL=redis://localhost:6379/0
DRUID_URL=http://localhost:8888
ELASTICSEARCH_URL=http://localhost:9200
POSTGRES_DSN=postgresql+asyncpg://mip:mip_local@localhost:5432/mip
LOG_LEVEL=INFO

# ---- Redis (no auth by default for local dev) -------------------------
# REDIS_PASSWORD=

# ---- Elasticsearch (security disabled for local dev) ------------------
# ES_JAVA_OPTS is set inline in compose; override here if needed.
# ES_JAVA_OPTS=-Xms512m -Xmx512m

# ---- Grafana ----------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- LLM (one OpenAI-compatible client for every provider) ------------
# Default is offline-safe MOCK_LLM. To go live: set MOCK_LLM=0 and OPENAI_API_KEY.
# OPENAI_BASE_URL targets any OpenAI-compatible endpoint:
#   OpenAI            https://api.openai.com/v1
#   Azure OpenAI      https://<resource>.openai.azure.com/openai/v1
#   Anthropic         https://api.anthropic.com/v1
#   OpenRouter        https://openrouter.ai/api/v1
#   Local (vLLM/etc.) http://localhost:8001/v1
MOCK_LLM=1
# MOCK_LLM=0
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Optional: New Relic APM (opt-in) ---------------------------------
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_CONFIG_FILE=
# NEW_RELIC_APP_NAME=
# NEW_RELIC_ENVIRONMENT=
